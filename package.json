{
  "name": "@chatman-media/sales",
  "version": "0.1.1",
  "description": "LLM-powered sales funnel engine — persona composition, A/B testing, ELO rating, self-play evaluation for conversational bots.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun test && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "biome check ./src",
    "format": "biome format --write ./src"
  },
  "keywords": [
    "sales-bot",
    "llm",
    "funnel",
    "elo",
    "self-play",
    "ab-testing",
    "telegram-bot",
    "chatbot",
    "openai",
    "ollama",
    "persuasion",
    "cialdini"
  ],
  "author": "Alexander Kireev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chatman-media/sales.git"
  },
  "homepage": "https://github.com/chatman-media/sales#readme",
  "bugs": {
    "url": "https://github.com/chatman-media/sales/issues"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@chatman/rag": "github:chatman-media/chatbot_rag#7e48cc9734ccba170d35ca1196607297711957e6",
    "@types/bun": "1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.1"
  }
}
